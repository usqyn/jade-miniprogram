<scroll-view scroll-y class="container" style="height: 100vh;">
  <view class="header-banner">
    <image class="banner-image" src="https://images.unsplash.com/photo-1603561591411-07134e71a2a9?w=800&q=80" mode="aspectFill" />
  </view>

  <view class="about-section">
    <view class="section-title">
      <text class="title-text">关于我们</text>
    </view>
    <view class="about-text">
      <text>我们专注于玉石文玩领域，为您提供高品质的玉石制品。</text>
      <text>专业鉴定、个性化定制、养护、真伪鉴别等专业咨询服务。</text>
    </view>
  </view>

  <view class="features-section">
    <view class="section-title">
      <text class="title-text">🏔️ 为什么选择我们？ 🏔️</text>
    </view>
    <view class="features-grid">
      <view class="feature-card">
        <text class="feature-icon">💎</text>
        <text class="feature-title">品质甄选</text>
        <view class="divider-line"></view>
        <text class="feature-desc">坚持源头严选·专业鉴品·双重标准</text>
      </view>
      <view class="feature-card">
        <text class="feature-icon">📦</text>
        <text class="feature-title">全阶适配</text>
        <view class="divider-line"></view>
        <text class="feature-desc">限量手作，按需匹配</text>
      </view>
      <view class="feature-card">
        <text class="feature-icon">💛</text>
        <text class="feature-title">贴心服务</text>
        <view class="divider-line"></view>
        <text class="feature-desc">支持专属定制购后提供养护技巧</text>
      </view>
    </view>
  </view>

  <view class="stores-section">
    <view class="section-title">
      <text class="title-text">🏔️ 线下门店 🏔️</text>
    </view>
    <view class="store-list">
      <view class="store-card" wx:for="{{stores}}" wx:key="id">
        <image class="store-image" src="{{item.image}}" mode="aspectFill" />
        <view class="store-info">
          <text class="store-name">{{item.name}}</text>
          <view class="store-address-row">
            <text class="store-icon">📍</text>
            <text class="store-address">{{item.address}}</text>
            <text class="store-distance">{{item.distance}}</text>
            <text class="arrow">→</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view style="height: 160rpx;"></view>
</scroll-view>

<view class="contact-buttons">
  <view class="contact-btn">
    <text class="contact-icon">↗</text>
  </view>
  <view class="contact-btn" bindtap="makePhoneCall">
    <text class="contact-icon">📞</text>
  </view>
  <view class="contact-btn wechat">
    <text class="contact-icon">💬</text>
  </view>
</view>
