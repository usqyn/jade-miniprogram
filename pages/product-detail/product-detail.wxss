.container {
  padding: 0;
  background-color: #f5f5f5;
}

.image-swiper {
  width: 100%;
  height: 600rpx;
  background-color: #fff;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.product-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 30rpx;
  background-color: #fff;
}

.product-name {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.share-btn {
  margin-left: 20rpx;
  padding: 10rpx;
}

.share-icon {
  font-size: 40rpx;
  color: #666;
}

.product-price-section {
  display: flex;
  align-items: center;
  padding: 0 30rpx 30rpx;
  background-color: #fff;
  gap: 20rpx;
}

.product-price {
  font-size: 44rpx;
  font-weight: bold;
  color: #8B6914;
}

.product-orders {
  font-size: 28rpx;
  color: #666;
}

.divider {
  height: 20rpx;
  background-color: #f5f5f5;
}

.detail-section {
  padding: 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.title-line {
  width: 8rpx;
  height: 32rpx;
  background-color: #8B6914;
  margin-right: 20rpx;
  border-radius: 4rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.detail-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.brand-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  background-color: #f5f5f5;
}

.brand-logo {
  width: 200rpx;
  height: 60rpx;
  opacity: 0.5;
  margin-bottom: 16rpx;
}

.brand-text {
  font-size: 24rpx;
  color: #999;
}

.contact-buttons {
  position: fixed;
  right: 30rpx;
  bottom: 260rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 100;
}

.contact-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.contact-btn.wechat {
  background-color: #07c160;
}

.contact-icon {
  font-size: 44rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  height: 140rpx;
  background-color: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  gap: 20rpx;
  z-index: 99;
}

.phone-btn {
  width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 2rpx solid #eee;
}

.phone-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.phone-text {
  font-size: 24rpx;
  color: #666;
}

.reserve-btn {
  flex: 1;
  background-color: #8B6914;
  border-radius: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reserve-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}
