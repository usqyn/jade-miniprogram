.container {
  padding: 0;
  background-color: #f5f5f5;
}

.header-banner {
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.about-section {
  padding: 40rpx 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.section-title {
  text-align: center;
  margin-bottom: 30rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.about-text {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.about-text text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.features-section {
  padding: 40rpx 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
}

.feature-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.feature-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.divider-line {
  width: 40rpx;
  height: 2rpx;
  background-color: #e0e0e0;
  margin-bottom: 16rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #666;
  line-height: 1.5;
}

.stores-section {
  padding: 40rpx 30rpx;
  background-color: #fff;
}

.store-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.store-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #f0f0f0;
}

.store-image {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.store-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.store-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.store-address-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.store-icon {
  font-size: 28rpx;
}

.store-address {
  font-size: 24rpx;
  color: #666;
  flex: 1;
}

.store-distance {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.arrow {
  font-size: 28rpx;
  color: #8B6914;
}

.contact-buttons {
  position: fixed;
  right: 30rpx;
  bottom: 200rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 100;
}

.contact-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.contact-btn.wechat {
  background-color: #07c160;
}

.contact-icon {
  font-size: 44rpx;
}
