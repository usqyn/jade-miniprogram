.container {
  padding: 0;
  background-color: #f5f5f5;
}

.search-section {
  padding: 30rpx;
  background-color: #fff;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 60rpx;
  padding: 20rpx 30rpx;
}

.search-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.category-scroll {
  white-space: nowrap;
  background-color: #fff;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.category-list {
  display: flex;
  gap: 40rpx;
  padding: 0 30rpx;
}

.category-item {
  padding: 16rpx 24rpx;
  position: relative;
}

.category-item.active .category-text {
  color: #333;
  font-weight: bold;
  font-size: 36rpx;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #9c27b0;
  border-radius: 3rpx;
}

.category-text {
  font-size: 30rpx;
  color: #666;
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 30rpx;
}

.product-item {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #e0e0e0;
}

.product-image {
  width: 100%;
  height: 360rpx;
  background-color: #f5f5f5;
}

.product-info {
  padding: 24rpx;
}

.product-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.product-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #9c27b0;
}

.cart-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #9c27b0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  font-size: 36rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.cart-float {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 120rpx;
  height: 120rpx;
  background-color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  border: 2rpx solid #e0e0e0;
  z-index: 100;
}

.cart-float-icon {
  font-size: 56rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 40rpx;
  height: 40rpx;
  background-color: #ff5722;
  border-radius: 20rpx;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}
